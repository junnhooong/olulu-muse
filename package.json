{
  "name": "olulu-muse",
  "version": "0.1.0",
  "description": "Discord music bot that plays YouTube audio",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "deploy-commands": "tsx scripts/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test 'test/**/*.test.ts'"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@discordjs/voice": "^0.18.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "sodium-native": "^4.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
